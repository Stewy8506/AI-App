# ==============================================================================
# Node & Next.js (Frontend) Ignore Rules
# ==============================================================================
node_modules/
.next/
out/
build/
dist/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Dependency directories
jspm_packages/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# ==============================================================================
# Python & FastAPI (Backend) Ignore Rules
# ==============================================================================
__pycache__/
*.py[cod]
*$py.class
.Python
venv/
.venv/
env/
ENV/
non-venv/

# DB Schema & SQLite databases
*.db
*.sqlite
*.sqlite3

# Pydantic / MyPy / Pytest caching
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
htmlcov/

# ==============================================================================
# Global & Environment Config Ignore Rules
# ==============================================================================
# Sensitive credentials & environment configurations
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.backup
*.env*
!*.env.example

# OS Metadata / General Editor Files
.DS_Store
Thumbs.db
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
pip-log.txt
